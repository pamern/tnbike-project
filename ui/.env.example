# Local UI server
UI_PORT=8501
UI_SESSION_SECRET=change-me-random-32-chars

# Optional defaults. The UI can also collect these at runtime and keep them
# only in the server-side session.
PGHOST=localhost
PGPORT=5432
PGDATABASE=tnbike_db
PGUSER=postgres
PGPASSWORD=postgres
DB_SCHEMA=tnbike

# Optional. Prefer entering keys in the UI Settings page for local demos.
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

