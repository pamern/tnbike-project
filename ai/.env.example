# PostgreSQL connection reused from the existing TNBIKE project
PGHOST=localhost
PGPORT=5432
PGDATABASE=tnbike_db
PGUSER=postgres
PGPASSWORD=postgres
DB_SCHEMA=tnbike

# AI provider. Supported values: groq, openai, anthropic, openrouter.
LLM_PROVIDER=groq
LLM_MODEL=

GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
GROQ_PER_KEY_ATTEMPTS=1
GROQ_KEY_COOLDOWN_SECONDS=60

OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_API_KEYS=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=openai/gpt-4o-mini

LLM_MAX_TOKENS=1200

# Output and logging
REPORT_OUTPUT_DIR=ai/report/output
AI_LOG_LEVEL=INFO
