<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TNBIKE AI Report - {{ generated_at }}</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #17202a;
      --muted: #5f6b7a;
      --line: #d8dee6;
      --band: #f4f7f9;
      --accent: #0f766e;
      --warn: #9a3412;
    }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--ink);
      background: #ffffff;
      line-height: 1.45;
    }
    header {
      padding: 32px 40px 24px;
      border-bottom: 1px solid var(--line);
      background: var(--band);
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 32px 48px;
    }
    h1, h2, h3 {
      margin: 0 0 12px;
      line-height: 1.2;
    }
    h1 {
      font-size: 28px;
    }
    h2 {
      margin-top: 32px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
      font-size: 21px;
    }
    h3 {
      margin-top: 20px;
      font-size: 16px;
    }
    p {
      margin: 8px 0;
    }
    .meta, .muted {
      color: var(--muted);
      font-size: 13px;
    }
    .kpis {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 16px 0 24px;
    }
    .kpi {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .kpi .label {
      color: var(--muted);
      font-size: 12px;
    }
    .kpi .value {
      margin-top: 4px;
      font-size: 20px;
      font-weight: 700;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 24px;
      font-size: 13px;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: var(--band);
      font-weight: 700;
    }
    .insight {
      border-left: 4px solid var(--accent);
      padding: 10px 14px;
      margin: 12px 0;
      background: #f7fbfa;
    }
    .warning {
      border-left-color: var(--warn);
      background: #fff7ed;
    }
    ul {
      margin: 8px 0 16px 22px;
      padding: 0;
    }
    @media (max-width: 700px) {
      header {
        padding: 24px 20px 18px;
      }
      main {
        padding: 22px 18px 36px;
      }
      table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>TNBIKE Strategic Executive Intelligence Report</h1>
    <p class="meta">Generated at {{ generated_at }} | Window: {{ date_from }} to {{ date_to }} | Dry run: {{ dry_run }}</p>
  </header>
  <main>
    <section>
      <h2>Business Situation</h2>
      <div class="kpis">
        <div class="kpi"><div class="label">Orders</div><div class="value">{{ metrics.order_count }}</div></div>
        <div class="kpi"><div class="label">Active Dealers</div><div class="value">{{ metrics.active_customer_count }}</div></div>
        <div class="kpi"><div class="label">Revenue</div><div class="value">{{ metrics.total_revenue }}</div></div>
        <div class="kpi"><div class="label">AOV</div><div class="value">{{ metrics.avg_order_value }}</div></div>
      </div>
      <p>{{ executive_narrative.business_situation }}</p>

      <h2>Executive Narrative</h2>
      <h3>Hidden Patterns</h3>
      <ul>{% for item in executive_narrative.hidden_patterns %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Strategic Risks</h3>
      <ul>{% for item in executive_narrative.strategic_risks %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Growth Opportunities</h3>
      <ul>{% for item in executive_narrative.growth_opportunities %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Prioritized Actions</h3>
      <ul>{% for item in executive_narrative.prioritized_actions %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>

      <h2>Strategic Insights</h2>
      {% for insight in strategic_insights %}
        <div class="insight">
          <h3>{{ insight.title }}</h3>
          <p><strong>What is happening:</strong> {{ insight.what_is_happening }}</p>
          <p><strong>Why it is happening:</strong> {{ insight.why_it_is_happening }}</p>
          <p><strong>Quantitative evidence:</strong> {{ insight.quantitative_evidence | join("; ") }}</p>
          <p><strong>Benchmark comparison:</strong> {{ insight.benchmark_comparison }}</p>
          <p><strong>Root-cause reasoning:</strong> {{ insight.root_cause_reasoning }}</p>
          <p><strong>Long-term impact:</strong> {{ insight.long_term_impact }}</p>
          <p><strong>Risk if ignored:</strong> {{ insight.risk_if_ignored }}</p>
          <p><strong>Optimal lever:</strong> {{ insight.optimal_lever }}</p>
          <p><strong>Highest ROI action:</strong> {{ insight.highest_roi_action }}</p>
          <p><strong>Strategic implication:</strong> {{ insight.strategic_implication }}</p>
          <p class="muted">Confidence: {{ insight.confidence }}</p>
        </div>
      {% else %}
        <div class="insight warning">
          <h3>Strategic synthesis unavailable</h3>
          <p>Run without <code>--dry-run</code> and configure <code>GROQ_API_KEYS</code> to generate consultant-grade insights.</p>
        </div>
      {% endfor %}

      <h3>Product Group Snapshot</h3>
      <table>
        <thead><tr><th>Group</th><th>Revenue</th><th>Qty</th><th>Orders</th><th>Share</th></tr></thead>
        <tbody>
        {% for row in product_rows %}
          <tr>
            <td>{{ row.group_name }}</td>
            <td>{{ row.total_revenue_fmt }}</td>
            <td>{{ row.total_qty_fmt }}</td>
            <td>{{ row.order_count }}</td>
            <td>{{ row.revenue_share_fmt }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Predictive Results & Strategic Insights</h2>
      <div class="kpis">
        <div class="kpi"><div class="label">Q2 Revenue Forecast</div><div class="value">{{ forecast_metrics.q2_total_revenue_forecast }}</div></div>
        <div class="kpi"><div class="label">Forecast Method</div><div class="value">{{ forecast_metrics.methods }}</div></div>
        <div class="kpi"><div class="label">High Risk Dealers</div><div class="value">{{ churn_summary.high_risk_count }}</div></div>
        <div class="kpi"><div class="label">Dealers Scored</div><div class="value">{{ churn_summary.customer_count }}</div></div>
      </div>

      <h3>Multi-Scenario Forecast</h3>
      <table>
        <thead><tr><th>Scenario</th><th>Forecast</th></tr></thead>
        <tbody>
          <tr><td>Pessimistic</td><td>{{ scenario.pessimistic }}</td></tr>
          <tr><td>Base</td><td>{{ scenario.base }}</td></tr>
          <tr><td>Optimistic</td><td>{{ scenario.optimistic }}</td></tr>
        </tbody>
      </table>
      <p><strong>Confidence interval explanation:</strong> {{ scenario.confidence_interval_explanation }}</p>
      <p><strong>Key drivers:</strong> {{ scenario.key_drivers | join("; ") }}</p>
      <p><strong>Sensitivity:</strong> {{ scenario.sensitivity_analysis | join("; ") }}</p>

      <h3>Q2 Forecast by Product Group</h3>
      <table>
        <thead><tr><th>Group</th><th>Revenue</th><th>Qty</th><th>Low</th><th>High</th></tr></thead>
        <tbody>
        {% for row in forecast_group_rows %}
          <tr>
            <td>{{ row.group_name }}</td>
            <td>{{ row.forecast_revenue_q2_fmt }}</td>
            <td>{{ row.forecast_qty_q2_fmt }}</td>
            <td>{{ row.lower_revenue_q2_fmt }}</td>
            <td>{{ row.upper_revenue_q2_fmt }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>

      <h3>Color Strategy</h3>
      <p><strong>Rising:</strong> {{ reasoning.color_strategy.rising_colors | join(", ") }}</p>
      <p><strong>Declining:</strong> {{ reasoning.color_strategy.declining_colors | join(", ") }}</p>
      <p>{{ reasoning.color_strategy.recommendation }}</p>

      <h3>Dealer Actions</h3>
      <p><strong>Retention priority:</strong> {{ reasoning.dealer_actions.retention_priority | join(", ") }}</p>
      <p>{{ reasoning.dealer_actions.strategy }}</p>

      <h3>Prioritized Strategic Recommendations</h3>
      <table>
        <thead>
          <tr><th>Priority</th><th>Score</th><th>Recommendation</th><th>Impact</th><th>Complexity</th><th>ROI</th><th>Dependency</th><th>Timeline</th></tr>
        </thead>
        <tbody>
        {% for item in strategic_recommendations %}
          <tr>
            <td>{{ item.priority }}</td>
            <td>{{ item.prioritization_score }}</td>
            <td>{{ item.recommendation }}</td>
            <td>{{ item.expected_business_impact }}</td>
            <td>{{ item.implementation_complexity }}</td>
            <td>{{ item.estimated_roi }}</td>
            <td>{{ item.execution_dependency }}</td>
            <td>{{ item.timeline }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>

      <h2>Meta-Analysis, Data Confidence & Self-Critique</h2>
      <div class="insight warning">
        <h3>Data Quality Assessment</h3>
        <pre>{{ data_quality_assessment | tojson(indent=2) }}</pre>
      </div>
      <h3>Reflection Loop</h3>
      <p><strong>Removed low-value insights:</strong> {{ self_critique.removed_low_value_insights | join("; ") }}</p>
      <p><strong>Confidence notes:</strong> {{ self_critique.confidence_notes | join("; ") }}</p>
    </section>
  </main>
</body>
</html>
