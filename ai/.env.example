# PostgreSQL connection reused from the existing TNBIKE project
PGHOST=localhost
PGPORT=5432
PGDATABASE=tnbike_db
PGUSER=postgres
PGPASSWORD=postgres
DB_SCHEMA=tnbike

# AI provider
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
GROQ_PER_KEY_ATTEMPTS=1
GROQ_KEY_COOLDOWN_SECONDS=60
LLM_MAX_TOKENS=1200

# Output and logging
REPORT_OUTPUT_DIR=ai/report/output
AI_LOG_LEVEL=INFO
