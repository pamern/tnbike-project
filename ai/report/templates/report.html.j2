<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Báo cáo điều hành VIZOR - {{ generated_at }}</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #17202a;
      --muted: #5f6b7a;
      --line: #d8dee6;
      --band: #f4f7f9;
      --accent: #0f766e;
      --warn: #9a3412;
    }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--ink);
      background: #ffffff;
      line-height: 1.45;
    }
    header {
      padding: 32px 40px 24px;
      border-bottom: 1px solid var(--line);
      background: var(--band);
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 32px 48px;
    }
    h1, h2, h3 {
      margin: 0 0 12px;
      line-height: 1.2;
    }
    h1 {
      font-size: 28px;
    }
    h2 {
      margin-top: 32px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
      font-size: 21px;
    }
    h3 {
      margin-top: 20px;
      font-size: 16px;
    }
    p {
      margin: 8px 0;
    }
    .meta, .muted {
      color: var(--muted);
      font-size: 13px;
    }
    .kpis {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 16px 0 24px;
    }
    .kpi {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .kpi .label {
      color: var(--muted);
      font-size: 12px;
    }
    .kpi .value {
      margin-top: 4px;
      font-size: 20px;
      font-weight: 700;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 24px;
      font-size: 13px;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: var(--band);
      font-weight: 700;
    }
    .insight {
      border-left: 4px solid var(--accent);
      padding: 10px 14px;
      margin: 12px 0;
      background: #f7fbfa;
    }
    .warning {
      border-left-color: var(--warn);
      background: #fff7ed;
    }
    ul {
      margin: 8px 0 16px 22px;
      padding: 0;
    }
    @media (max-width: 700px) {
      header {
        padding: 24px 20px 18px;
      }
      main {
        padding: 22px 18px 36px;
      }
      table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Báo cáo điều hành chiến lược VIZOR</h1>
    <p class="meta">Tạo lúc {{ generated_at }} | Kỳ dữ liệu: {{ date_from }} đến {{ date_to }} | Chế độ thử: {{ dry_run }}</p>
  </header>
  <main>
    <section>
      <h2>Tình hình kinh doanh</h2>
      <div class="kpis">
        <div class="kpi"><div class="label">Đơn hàng</div><div class="value">{{ metrics.order_count }}</div></div>
        <div class="kpi"><div class="label">Đại lý hoạt động</div><div class="value">{{ metrics.active_customer_count }}</div></div>
        <div class="kpi"><div class="label">Doanh thu</div><div class="value">{{ metrics.total_revenue }}</div></div>
        <div class="kpi"><div class="label">Giá trị đơn bình quân</div><div class="value">{{ metrics.avg_order_value }}</div></div>
      </div>
      <p>{{ executive_narrative.business_situation }}</p>

      <h2>Tường thuật điều hành</h2>
      <h3>Mẫu hình ẩn</h3>
      <ul>{% for item in executive_narrative.hidden_patterns %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Rủi ro chiến lược</h3>
      <ul>{% for item in executive_narrative.strategic_risks %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Cơ hội tăng trưởng</h3>
      <ul>{% for item in executive_narrative.growth_opportunities %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>
      <h3>Hành động ưu tiên</h3>
      <ul>{% for item in executive_narrative.prioritized_actions %}<li>{{ item.action or item.recommendation or item.title or item.summary or item }}</li>{% endfor %}</ul>

      <h2>Insight chiến lược</h2>
      {% for insight in strategic_insights %}
        <div class="insight">
          <h3>{{ insight.title }}</h3>
          <p><strong>Diễn biến:</strong> {{ insight.what_is_happening }}</p>
          <p><strong>Nguyên nhân:</strong> {{ insight.why_it_is_happening }}</p>
          <p><strong>Bằng chứng định lượng:</strong> {{ insight.quantitative_evidence | join("; ") }}</p>
          <p><strong>So sánh chuẩn:</strong> {{ insight.benchmark_comparison }}</p>
          <p><strong>Lý giải gốc rễ:</strong> {{ insight.root_cause_reasoning }}</p>
          <p><strong>Tác động dài hạn:</strong> {{ insight.long_term_impact }}</p>
          <p><strong>Rủi ro nếu bỏ qua:</strong> {{ insight.risk_if_ignored }}</p>
          <p><strong>Đòn bẩy tối ưu:</strong> {{ insight.optimal_lever }}</p>
          <p><strong>Hành động ROI cao nhất:</strong> {{ insight.highest_roi_action }}</p>
          <p><strong>Hàm ý chiến lược:</strong> {{ insight.strategic_implication }}</p>
          <p class="muted">Độ tin cậy: {{ insight.confidence }}</p>
        </div>
      {% else %}
        <div class="insight warning">
          <h3>Chưa có tổng hợp chiến lược</h3>
          <p>Chạy không dùng <code>--dry-run</code> và cấu hình API key của nhà cung cấp để tạo insight ở cấp tư vấn.</p>
        </div>
      {% endfor %}

      <h3>Ảnh chụp nhóm sản phẩm</h3>
      <table>
        <thead><tr><th>Nhóm</th><th>Doanh thu</th><th>Số lượng</th><th>Đơn hàng</th><th>Tỷ trọng</th></tr></thead>
        <tbody>
        {% for row in product_rows %}
          <tr>
            <td>{{ row.group_name }}</td>
            <td>{{ row.total_revenue_fmt }}</td>
            <td>{{ row.total_qty_fmt }}</td>
            <td>{{ row.order_count }}</td>
            <td>{{ row.revenue_share_fmt }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Kết quả dự báo và hàm ý chiến lược</h2>
      <div class="kpis">
        <div class="kpi"><div class="label">Dự báo doanh thu Q2</div><div class="value">{{ forecast_metrics.q2_total_revenue_forecast }}</div></div>
        <div class="kpi"><div class="label">Phương pháp dự báo</div><div class="value">{{ forecast_metrics.methods }}</div></div>
        <div class="kpi"><div class="label">Đại lý rủi ro cao</div><div class="value">{{ churn_summary.high_risk_count }}</div></div>
        <div class="kpi"><div class="label">Đại lý đã chấm điểm</div><div class="value">{{ churn_summary.customer_count }}</div></div>
      </div>

      <h3>Dự báo theo nhiều kịch bản</h3>
      <table>
        <thead><tr><th>Kịch bản</th><th>Dự báo</th></tr></thead>
        <tbody>
          <tr><td>Thận trọng</td><td>{{ scenario.pessimistic }}</td></tr>
          <tr><td>Cơ sở</td><td>{{ scenario.base }}</td></tr>
          <tr><td>Tích cực</td><td>{{ scenario.optimistic }}</td></tr>
        </tbody>
      </table>
      <p><strong>Giải thích khoảng tin cậy:</strong> {{ scenario.confidence_interval_explanation }}</p>
      <p><strong>Động lực chính:</strong> {{ scenario.key_drivers | join("; ") }}</p>
      <p><strong>Độ nhạy:</strong> {{ scenario.sensitivity_analysis | join("; ") }}</p>

      <h3>Dự báo Q2 theo nhóm sản phẩm</h3>
      <table>
        <thead><tr><th>Nhóm</th><th>Doanh thu</th><th>Số lượng</th><th>Thấp</th><th>Cao</th></tr></thead>
        <tbody>
        {% for row in forecast_group_rows %}
          <tr>
            <td>{{ row.group_name }}</td>
            <td>{{ row.forecast_revenue_q2_fmt }}</td>
            <td>{{ row.forecast_qty_q2_fmt }}</td>
            <td>{{ row.lower_revenue_q2_fmt }}</td>
            <td>{{ row.upper_revenue_q2_fmt }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>

      <h3>Chiến lược màu sắc</h3>
      <p><strong>Đang tăng:</strong> {{ reasoning.color_strategy.rising_colors | join(", ") }}</p>
      <p><strong>Đang giảm:</strong> {{ reasoning.color_strategy.declining_colors | join(", ") }}</p>
      <p>{{ reasoning.color_strategy.recommendation }}</p>

      <h3>Hành động với đại lý</h3>
      <p><strong>Ưu tiên giữ chân:</strong> {{ reasoning.dealer_actions.retention_priority | join(", ") }}</p>
      <p>{{ reasoning.dealer_actions.strategy }}</p>

      <h3>Khuyến nghị chiến lược ưu tiên</h3>
      <table>
        <thead>
          <tr><th>Ưu tiên</th><th>Điểm</th><th>Khuyến nghị</th><th>Tác động</th><th>Độ phức tạp</th><th>ROI</th><th>Phụ thuộc</th><th>Thời hạn</th></tr>
        </thead>
        <tbody>
        {% for item in strategic_recommendations %}
          <tr>
            <td>{{ item.priority }}</td>
            <td>{{ item.prioritization_score }}</td>
            <td>{{ item.recommendation }}</td>
            <td>{{ item.expected_business_impact }}</td>
            <td>{{ item.implementation_complexity }}</td>
            <td>{{ item.estimated_roi }}</td>
            <td>{{ item.execution_dependency }}</td>
            <td>{{ item.timeline }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>

      <h2>Phân tích độ tin cậy dữ liệu và tự phản biện</h2>
      <div class="insight warning">
        <h3>Đánh giá chất lượng dữ liệu</h3>
        <ul>{% for item in data_quality_assessment_lines %}<li>{{ item }}</li>{% endfor %}</ul>
      </div>
      <h3>Vòng phản biện</h3>
      <p><strong>Insight giá trị thấp đã loại bỏ:</strong> {{ self_critique.removed_low_value_insights | join("; ") }}</p>
      <p><strong>Ghi chú độ tin cậy:</strong> {{ self_critique.confidence_notes | join("; ") }}</p>
    </section>
  </main>
</body>
</html>
